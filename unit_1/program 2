# tuple
t1 = (10, 20, 30, 40)
print("Tuple:", t1)

print("Element at index 0:", t1[0])
print("Element at index 2:", t1[2])

t2 = (("Amit", 101), ("Riya", 102))
print("Nested Tuple:", t2)

t3 = t1 + (50, 60)
print("After concatenation:", t3)

t4 = t1 * 2
print("After repetition:", t4)
